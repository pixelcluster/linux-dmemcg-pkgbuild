pkgname = linux-dmemcg
	pkgdesc = The Linux (dmem cgroup development tree) kernel and modules
	depends = coreutils
	depends = initramfs
	depends = kmod
	optdepends = linux-dmemcg-headers: headers and scripts for building modules
